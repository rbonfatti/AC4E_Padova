{
  "_comment": "Example Claude Code MCP config for a FRED/public-data metadata server. Copy to .mcp.json at the repository root. Keep FRED_API_KEY in the environment; do not commit secrets.",
  "mcpServers": {
    "fred": {
      "type": "stdio",
      "command": "python3",
      "args": ["-m", "fred_mcp_server"],
      "env": {
        "FRED_API_KEY": "${FRED_API_KEY}",
        "PYTHONPATH": "${CLAUDE_PROJECT_DIR}/agent-harness/mcp/fred/src"
      }
    }
  }
}
